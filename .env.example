TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_BOT_USERNAME=DJ_notification_bot
DATABASE_URL=postgres://telegram:telegram@localhost:5432/telegram_server?sslmode=disable
HTTP_LISTEN_ADDR=127.0.0.1:8080
LOG_LEVEL=info

# Admin UI (cmd/adminui) — 운영자 브라우저 로그인 비밀번호. compose 기본값(placeholder)을 반드시 교체.
ADMINUI_PASSWORD=change-me-admin-pw
# Admin UI가 서버 /admin API 호출에 사용하는 admin capability API 키 (브라우저에 절대 노출되지 않음)
ADMINUI_API_KEY=tg_<prefix>_<secret>
