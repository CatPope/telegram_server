FROM golang:1.26-alpine AS build
WORKDIR /src
RUN apk add --no-cache git ca-certificates
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/adminui ./cmd/adminui

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/adminui /adminui
USER nonroot:nonroot
EXPOSE 8081
ENTRYPOINT ["/adminui"]
